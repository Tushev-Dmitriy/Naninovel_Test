@hideChars time:0 remove:true
@char Key pos:50,0 scale:0.5 time:0
@if hasKey==true||hasQuestItem==true
@print "Ключ: Уже подобран."
@hidePrinter 
@else
@set ticTacToeWon=false
@clearChoice *
@hidePrinter 
@playTicTacToe
@if ticTacToeWon==true
@set hasKey=true
@print "Ключ: Получен."
@hidePrinter 
@endif
@endif
@hideChars time:0 remove:true
@goto Location3
