@hideChars time:0 remove:true
@char Key pos:50,0 scale:1.35 time:0
@if "hasKey==true||hasQuestItem==true"
@print "Key: Already collected."
@hidePrinter
@else
@set ticTacToeWon=false
@clearChoice *
@hidePrinter
@playTicTacToe
@if ticTacToeWon==true
@set hasKey=true
@print "Key: Collected."
@hidePrinter
@endif
@endif
@hideChars time:0 remove:true
@goto Location3
