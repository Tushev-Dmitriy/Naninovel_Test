@clearChoice *
@set currentLocation=1
@back Location1 time:0
@hideChars time:0 remove:true
@choice "Talk to NPC" button:ChoiceButtons/CompactChoiceButton pos:0,-245 handler:ButtonArea goto:NpcInteract
@choice "Location 1" button:ChoiceButtons/CompactChoiceButton pos:-820,220 handler:ButtonArea goto:StayOnLocation1
@choice "Location 2" button:ChoiceButtons/CompactChoiceButton pos:-820,165 handler:ButtonArea goto:Location2
@choice "Location 3" button:ChoiceButtons/CompactChoiceButton pos:-820,110 handler:ButtonArea goto:Location3
@stop
