@clearChoice *
@set currentLocation=1
@back Location1 time:0
@hideChars time:0 remove:true
@char Npc pos:80,25 scale:0.25 time:0
@choice "Локация 1" button:ChoiceButtons/CompactChoiceButton pos:36,36 handler:ButtonArea goto:StayOnLocation1
@choice "Локация 2" button:ChoiceButtons/CompactChoiceButton pos:36,96 handler:ButtonArea goto:Location2
@choice "Локация 3" button:ChoiceButtons/CompactChoiceButton pos:36,156 handler:ButtonArea goto:Location3
@stop
