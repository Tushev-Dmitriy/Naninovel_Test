@clearChoice *
@set currentLocation=2
@back Location2 time:0
@hideChars time:0 remove:true
@choice "Check safe" button:ChoiceButtons/CompactChoiceButton pos:0,-245 handler:ButtonArea goto:SafeInteract
@choice "Location 1" button:ChoiceButtons/CompactChoiceButton pos:-820,220 handler:ButtonArea goto:Location1
@choice "Location 2" button:ChoiceButtons/CompactChoiceButton pos:-820,165 handler:ButtonArea goto:StayOnLocation2
@choice "Location 3" button:ChoiceButtons/CompactChoiceButton pos:-820,110 handler:ButtonArea goto:Location3
@stop
