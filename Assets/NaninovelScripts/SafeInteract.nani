@hideChars time:0 remove:true
@char Safe pos:50,5 scale:0.5 time:0
@if hasQuestItem==true
@print "Сейф: Он уже открыт."
@hidePrinter 
@elseif hasKey==false
@set checkedSafe=true
@print "Сейф: Закрыт. Нужен ключ."
@hidePrinter 
@else
@set hasKey=false
@set hasQuestItem=true
@print "Сейф: Открыто. Внутри лежал старинный амулет."
@hidePrinter 
@endif
@hideChars time:0 remove:true
@goto Location2
